# --- Copy to .env and fill in. .env is gitignored; never commit real values. ---

# Absolute path to the Obsidian vault root (required).
VAULT_PATH=/path/to/your/Obsidian/Vault

# Auth mode: token | github | none
#   token  — static Bearer token (works with Claude Code `--header`, NOT the
#            claude.ai / Claude Desktop custom-connector UI, which has no header field)
#   github — GitHub OAuth (works with Claude Desktop / claude.ai remote connectors)
#   none   — no auth (only safe on a fully trusted/private network)
# If left blank, it is inferred: github if GITHUB_CLIENT_ID is set, else token if
# MCP_AUTH_TOKEN is set, else none.
AUTH_MODE=

# --- token mode ---
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=

# --- github mode (OAuth) ---
# Register an OAuth App at https://github.com/settings/developers
#   Homepage URL:            https://your-public-host
#   Authorization callback:  https://your-public-host/auth/callback
# Then paste the credentials here. BASE_URL must be the PUBLIC https URL your
# reverse proxy serves (used in OAuth metadata + redirects).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
BASE_URL=
# Comma-separated GitHub logins allowed to connect. REQUIRED in github mode —
# OAuth proves identity, this decides who is authorized. Fail-closed.
GITHUB_ALLOWED_USERS=

# HTTP bind. Keep host on localhost and let your reverse proxy / TLS terminate
# the public domain:port and forward to this address.
MCP_HOST=127.0.0.1
MCP_PORT=8848
MCP_PATH=/mcp

# Optional external helper binaries. Leave blank to disable the matching tool.
# These are looked up on PATH if a bare name is given.

# Warm semantic-search front-end, called as `<bin> "<query>" -n <limit>`.
# Preferred over QMD_BIN for `vault_search mode=semantic` when set.
FAST_SEARCH_BIN=

QMD_BIN=qmd
WIKI_QUERY_BIN=wiki-query
SAVE_LINK_BIN=obsidian-save-link

# Optional: command run to rebuild the wiki index when a tool is called with
# rebuild_index=true. Leave blank to disable index rebuilds entirely.
INDEX_REBUILD_CMD=
