# --- Copy to .env and fill in. .env is gitignored; never commit real values. ---

# Absolute path to the Obsidian vault root (required).
VAULT_PATH=/path/to/your/Obsidian/Vault

# Bearer token required on every request (Authorization: Bearer <token>).
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# If unset, the server runs WITHOUT auth (only safe behind a trusted network).
MCP_AUTH_TOKEN=

# HTTP bind. Keep host on localhost and let your reverse proxy / TLS terminate
# the public domain:port and forward to this address.
MCP_HOST=127.0.0.1
MCP_PORT=8848
MCP_PATH=/mcp

# Optional external helper binaries. Leave blank to disable the matching tool.
# These are looked up on PATH if a bare name is given.

# Warm semantic-search front-end, called as `<bin> "<query>" -n <limit>`.
# Preferred over QMD_BIN for `vault_search mode=semantic` when set.
FAST_SEARCH_BIN=

QMD_BIN=qmd
WIKI_QUERY_BIN=wiki-query
SAVE_LINK_BIN=obsidian-save-link

# Optional: command run to rebuild the wiki index when a tool is called with
# rebuild_index=true. Leave blank to disable index rebuilds entirely.
INDEX_REBUILD_CMD=
